# Copy to .env and adjust as needed.

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=Asia/Taipei
DJANGO_LOG_LEVEL=INFO

# sqlite (default, local dev): DATABASE_URL=sqlite:///db.sqlite3
# postgres (docker-compose / production):
DATABASE_URL=postgres://dailyos:dailyos@db:5432/dailyos

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DRF_THROTTLE_USER=1000/min
DRF_THROTTLE_ANON=60/min

DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false

# Set true only for local/CI test runs without a Redis instance available.
DJANGO_TEST_MODE=false
